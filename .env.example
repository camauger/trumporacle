DATABASE_URL=postgresql+psycopg://trumporacle:trumporacle@127.0.0.1:5432/trumporacle
# Neon (managed Postgres): paste from Dashboard → Connect → psycopg. Use TLS:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# ``postgres://`` from Neon/Heroku is accepted and normalized to psycopg.
# Serverless runtimes: prefer Neon’s pooled connection string when offered; run Alembic from CI or a dev machine (direct endpoint if Neon recommends it for DDL).
ANTHROPIC_API_KEY=
# Default = claude-haiku-4-5 (cheapest viable). Override here if you want Sonnet/Opus.
ANTHROPIC_MODEL=claude-haiku-4-5
# Trump's Truth (Defending Democracy Together) — RSS/XML archive; avoids truthsocial.com SPA HTML.
# Full feed: https://www.trumpstruth.org/feed
# Optional window (example): https://www.trumpstruth.org/feed?start_date=2024-01-01&end_date=2024-01-31
TRUTH_SOCIAL_RSS_URL=https://www.trumpstruth.org/feed
# Leave blank or omit if unused — empty TELEGRAM_* lines are OK (no Docker required for Neon-only setups).
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
MLFLOW_TRACKING_URI=file:./mlruns
ARTIFACTS_DIR=artifacts
DISCORD_WEBHOOK_URL=
LOG_JSON=false
